# ---- Listener ----
LISTEN_HOST=127.0.0.1
LISTEN_PORT=8088

# ---- Jira (Cloud) ----
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@moveware.com
JIRA_API_TOKEN=...  # Atlassian API token

# Account IDs (not display names) for assignments
JIRA_AI_ACCOUNT_ID=...      # AI Runner accountId
JIRA_HUMAN_ACCOUNT_ID=...   # Leigh's accountId

# Shared secret used by Jira Automation when calling the webhook
JIRA_WEBHOOK_SECRET=change-me

# Pilot workflow statuses (must match Jira)
JIRA_STATUS_BACKLOG=Backlog
JIRA_STATUS_PLAN_REVIEW=Plan Review
JIRA_STATUS_SELECTED_FOR_DEV=Selected for Development
JIRA_STATUS_IN_PROGRESS=In Progress
JIRA_STATUS_IN_TESTING=In Testing
JIRA_STATUS_NEEDS_REWORK=Needs Rework
JIRA_STATUS_DONE=Done
JIRA_STATUS_BLOCKED=Blocked

# ---- Repo settings (GitHub) ----
REPO_SSH=git@github.com:leigh-moveware/online-docs.git
REPO_WORKDIR=/srv/ai/repos/online-docs
BASE_BRANCH=main
REPO_OWNER_SLUG=leigh-moveware
REPO_NAME=online-docs

# ---- GitHub Authentication ----
# Option 1: Personal Access Token (PAT) - Simple but less secure for orgs
GH_TOKEN=...

# Option 2: GitHub App (Recommended for production/organizations)
# More secure, better audit trail, fine-grained permissions, auto token rotation
# Leave these blank to use PAT (Option 1 above)
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678  # Optional, will auto-detect if not set
# GITHUB_APP_PRIVATE_KEY_PATH=/srv/ai/.ssh/github-app-private-key.pem

# ---- LLM providers ----
# OpenAI API (used for planning + self-healing escalation)
OPENAI_API_KEY=...
OPENAI_MODEL=gpt-5.2-codex  # Uses OpenAI Responses API (/v1/responses)
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude API (implementation)
ANTHROPIC_API_KEY=...
ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Latest Claude Sonnet 4
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional hardening
DEBUG=false

# ---- Verification / Self-Healing (Optional) ----
# Max LLM fix attempts before failing (default: 7, increased for 95%+ accuracy)
# MAX_FIX_ATTEMPTS=7

# ---- Queue Management (Optional) ----
# Enable smart queue with priorities and conflict avoidance
USE_SMART_QUEUE=true

# ---- Story Auto-Start (Optional) ----
# Enable automatic sequential processing of Stories within an Epic
# When true, the AI will automatically start the next Story after completing one
# When false, Stories must be manually moved to "Selected for Development"
# Default: true
AUTO_START_NEXT_STORY=true

# ---- Story branch base (Optional) ----
# When creating a new story branch, use the latest existing story branch as base
# instead of main. This avoids merge conflicts when merging PRs in story order.
# Set to false to always branch from main (then merge main before starting next story).
# Default: true
# STORY_CHAIN_FROM_PREVIOUS=true

# ---- Post-deploy ticket (Optional) ----
# When true, the runner creates a Jira subtask (assigned to you) with explicit steps
# for database creation, .env setup, and migrations when Prisma/env/migrations change.
# CREATE_POST_DEPLOY_TICKET=true

# ---- Logging (Optional) ----
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: human (colored) or json (structured)
LOG_FORMAT=human
# Optional: log to file (in addition to console)
# LOG_FILE=/srv/ai/logs/worker.log

# ---- Multi-Repository Configuration (Optional) ----
# Path to repos.json for multi-repo support
# If not set, uses config/repos.json by default
# REPOS_CONFIG_PATH=/srv/ai/app/config/repos.json

# Base directory for repo workdirs (used by Add Repository page)
# Default: /srv/ai/repos
# REPOS_BASE_DIR=/srv/ai/repos

# ---- Add Repository Page (Optional) ----
# If set, POST /api/repos/add requires X-Admin-Secret header matching this value
# ADMIN_SECRET=your-admin-secret

# ---- Project Knowledge for Planning (Optional) ----
# Path to project-knowledge.md. Injected into the planner so the AI does not ask
# basic questions about infrastructure, cloud, deployment, etc. Default: config/project-knowledge.md
# PROJECT_KNOWLEDGE_PATH=/srv/ai/app/config/project-knowledge.md

# ---- GitHub Auto-Deploy Webhook (Optional) ----
# Secret for GitHub webhook to trigger auto-deployment
# Generate with: openssl rand -hex 32
# GITHUB_DEPLOY_WEBHOOK_SECRET=your-secret-here

# ---- External Service Integrations (Optional) ----
# These extend the AI orchestrator with design, error tracking, and testing capabilities.
# Each integration is auto-detected: if credentials are set, the feature activates.

# Figma - reads design specs from Figma URLs in Jira stories
# Generate a Personal Access Token at: https://www.figma.com/developers/api#access-tokens
# FIGMA_ACCESS_TOKEN=figd_xxx

# Sentry - queries error details for AI-assisted bug remediation
# Generate at https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: event:read, project:read, org:read
# SENTRY_ACCESS_TOKEN=sntrys_xxx
# SENTRY_HOST=https://sentry.io
# SENTRY_ORG=your-org-slug

# BrowserStack - cross-browser responsive design testing after commits
# Sign up at https://www.browserstack.com, find keys under Settings > Access Key
# BROWSERSTACK_USERNAME=your-username
# BROWSERSTACK_ACCESS_KEY=your-access-key

# Stripe - fetches products/prices/webhooks so AI generates correct Stripe code
# Use test key (sk_test_xxx) for development. Generate at: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Slack - real-time notifications when tasks complete, fail, or need review
# Create app at https://api.slack.com/apps → Incoming Webhooks → Add to channel
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Lighthouse / PageSpeed - performance auditing for UI changes (free, optional key)
# Without key: ~25 requests/day. With key: ~25,000/day.
# Generate at: https://developers.google.com/speed/docs/insights/v5/get-started
# PAGESPEED_API_KEY=AIza...

# Vercel - no credentials needed. Best practices are automatically injected
# for any Next.js/React project (detected via skills list or project files).

# GitHub CI - no additional credentials needed. Uses GH_TOKEN already configured
# above. Automatically checks GitHub Actions status after pushing code.

# npm audit - no credentials needed. Runs automatically after npm install to
# detect known security vulnerabilities in dependencies. Reports critical/high
# issues to Jira and injects context for the LLM.

# Playwright E2E - no credentials needed. If the target repo has a
# playwright.config.ts, regression tests run automatically after each commit.
# The repo must have Playwright installed: npm i -D @playwright/test
# Install browsers with: npx playwright install chromium

# Security Scanner - no credentials needed. Runs automatically on every commit.
# Scans changed files for hardcoded secrets, SQL injection patterns, XSS vectors,
# insecure cookies, weak crypto, and OWASP-style vulnerabilities.

# Semgrep SAST - AST-aware security analysis with OWASP Top 10 data-flow tracking.
# Install CLI: pip install semgrep (no token needed for open-source rules).
# For full Pro rule coverage, sign up free at https://semgrep.dev and set:
# SEMGREP_APP_TOKEN=your-token-here

# OWASP ZAP DAST - dynamic security testing against deployed URLs.
# Runs ZAP in daemon mode (Docker recommended). Actively probes for injection,
# XSS, CSRF, auth issues, and other OWASP Top 10 runtime vulnerabilities.
# docker run -u zap -p 8080:8080 -d zaproxy/zap-stable zap.sh -daemon \
#   -host 0.0.0.0 -port 8080 -config api.addrs.addr.name=.* -config api.addrs.addr.regex=true
# ZAP_API_URL=http://localhost:8080
# ZAP_API_KEY=your-zap-api-key